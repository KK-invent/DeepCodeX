<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>DEEPCODEX_HOME</key>
		<string>__DEEPCODEX_HOME__</string>
		<key>CODEX_SOURCE_HOME</key>
		<string>__CODEX_SOURCE_HOME__</string>
		<key>PATH</key>
		<string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>Label</key>
	<string>__LAUNCHD_DOMAIN__.session-sync</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/python3</string>
		<string>__DEEPCODEX_HOME__/bin/deepcodex-session-import.py</string>
		<string>--source</string>
		<string>__CODEX_SOURCE_HOME__</string>
		<string>--target</string>
		<string>__DEEPCODEX_HOME__</string>
		<string>--include-history</string>
	</array>
	<key>WatchPaths</key>
	<array>
		<string>__CODEX_SOURCE_HOME__/sessions</string>
		<string>__CODEX_SOURCE_HOME__/archived_sessions</string>
		<string>__CODEX_SOURCE_HOME__/shell_snapshots</string>
		<string>__CODEX_SOURCE_HOME__/session_index.jsonl</string>
		<string>__CODEX_SOURCE_HOME__/state_5.sqlite</string>
	</array>
	<key>StartInterval</key>
	<integer>900</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>__DEEPCODEX_HOME__/logs/session-sync.err.log</string>
	<key>StandardOutPath</key>
	<string>__DEEPCODEX_HOME__/logs/session-sync.out.log</string>
	<key>WorkingDirectory</key>
	<string>__DEEPCODEX_HOME__</string>
</dict>
</plist>
