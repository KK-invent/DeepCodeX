# DeepCodex secret template.
# Copy to $DEEPCODEX_HOME/secrets.env or run:
#   $DEEPCODEX_HOME/bin/deepcodex-configure-deepseek.py
#
# Do not commit the real secrets.env file.

# Local bridge/shim auth key.
# Generated by deepcodex-configure-deepseek.py if missing.
CCX_PROXY_ACCESS_KEY=

# Public DeepSeek/OpenAI-compatible upstream URL.
# The bridge at 127.0.0.1:3000 forwards to this URL.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Your DeepSeek API key.
# Get one at https://platform.deepseek.com -> API Keys -> Create new key.
# After install, open DeepCodeX.app -> "Configure DeepSeek..." menu to fill this in,
# or edit this file directly and restart the bridge service.
DEEPSEEK_API_KEY=

# Optional. Enables image-to-text vision before forwarding text to DeepSeek.
# Not required for normal operation.
LONGCAT_API_KEY=
