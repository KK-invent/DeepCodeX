# DeepCodex secret template.
# Copy to $DEEPCODEX_HOME/secrets.env or run:
#   $DEEPCODEX_HOME/bin/deepcodex-configure-deepseek.py
#
# Do not commit the real secrets.env file.

# Required for the local DeepCodex -> shim -> ccx route.
# Generated by deepcodex-configure-deepseek.py if missing.
CCX_PROXY_ACCESS_KEY=

# Public DeepSeek/OpenAI-compatible upstream URL.
# DeepCodex itself still talks to the local shim at 127.0.0.1:3100.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional. Enables image-to-text vision before forwarding text to DeepSeek.
LONGCAT_API_KEY=
